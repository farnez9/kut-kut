{
	"name": "kut-kut",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun --filter=@kut-kut/studio dev",
		"build": "bun --filter=@kut-kut/studio build",
		"typecheck": "bun --filter='*' typecheck",
		"test": "bun test --pass-with-no-tests",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "^1.3.12",
		"typescript": "^6.0.3"
	}
}
